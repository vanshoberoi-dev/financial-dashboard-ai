# =============================================================================
# Indian Personal Finance Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# AI / LLM Configuration
# -----------------------------------------------------------------------------

# Google Gemini API Key for AI-powered financial insights and recommendations.
# Obtain your key from: https://makersuite.google.com/app/apikey
# Required for: portfolio analysis, tax suggestions, spending insights
GEMINI_API_KEY=your_gemini_api_key_here


# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# SQLAlchemy-compatible database connection URL.
# Default uses SQLite (no setup required, great for development).
# For production, consider switching to PostgreSQL:
#   postgresql+asyncpg://user:password@localhost:5432/finance_db
# For MySQL/MariaDB:
#   mysql+aiomysql://user:password@localhost:3306/finance_db
DATABASE_URL=sqlite:///./finance.db


# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing) Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# Add all URLs from which your frontend will make requests.
# Examples:
#   Single origin:    http://localhost:3000
#   Multiple origins: http://localhost:3000,https://myfinanceapp.in,https://www.myfinanceapp.in
# For development with multiple ports: http://localhost:3000,http://localhost:5173
# WARNING: Do NOT use wildcard (*) in production as it exposes your API to all origins.
CORS_ORIGINS=http://localhost:3000


# -----------------------------------------------------------------------------
# AMFI (Association of Mutual Funds in India) Configuration
# -----------------------------------------------------------------------------

# URL to fetch the latest NAV (Net Asset Value) for all mutual fund schemes.
# This is the official AMFI endpoint that returns NAV data for all schemes.
# The file is updated on every business day after market hours (approx. 11 PM IST).
# Documentation: https://www.amfiindia.com/net-asset-value
# Do NOT change this unless AMFI updates their endpoint.
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt


# -----------------------------------------------------------------------------
# MF Central API Configuration
# -----------------------------------------------------------------------------

# Base URL for the MF Central API, the official platform for mutual fund
# transactions and portfolio consolidation (backed by CAMS & KFintech).
# Used for: fetching consolidated account statements (CAS), transaction history,
# folio details, and SIP information.
# API access may require registration at: https://www.mfcentral.com
MF_CENTRAL_API_URL=https://api.mfcentral.com


# -----------------------------------------------------------------------------
# NSE (National Stock Exchange of India) Configuration
# -----------------------------------------------------------------------------

# Base URL for NSE India's public API endpoints.
# Used for: fetching live/historical stock quotes, indices (NIFTY 50, SENSEX),
# corporate actions, F&O data, and market statistics.
# Note: NSE may require specific headers (User-Agent, Referer, Cookie) for
# successful API calls. Refer to the data fetcher module for header configuration.
# Reference: https://www.nseindia.com
NSE_BASE_URL=https://www.nseindia.com/api


# -----------------------------------------------------------------------------
# Application Configuration (Optional - defaults are set in config.py)
# -----------------------------------------------------------------------------

# Application environment: development | staging | production
# Controls logging level, debug mode, and error verbosity.
# APP_ENV=development

# Secret key used for signing JWT tokens and session data.
# Generate a strong random key using: openssl rand -hex 32
# REQUIRED in production. Must be at least 32 characters long.
# SECRET_KEY=your_super_secret_key_minimum_32_characters_long

# JWT token expiry duration in minutes.
# Default is 60 minutes (1 hour). Adjust based on your security requirements.
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# Port on which the FastAPI application will run.
# Default: 8000
# APP_PORT=8000

# Host address to bind the application server.
# Use 0.0.0.0 to accept connections from all network interfaces.
# APP_HOST=0.0.0.0

# Number of Uvicorn worker processes (for production with Gunicorn).
# Recommended: (2 x CPU cores) + 1
# WORKERS=4


# -----------------------------------------------------------------------------
# Cache Configuration (Optional)
# -----------------------------------------------------------------------------

# Redis connection URL for caching NAV data, stock prices, and API responses.
# Caching reduces repeated calls to AMFI/NSE and improves response times.
# REDIS_URL=redis://localhost:6379/0

# Cache TTL (Time To Live) in seconds for market data (NAV, stock prices).
# Default: 900 seconds (15 minutes) â aligns with typical market data refresh rates.
# MARKET_DATA_CACHE_TTL=900


# -----------------------------------------------------------------------------
# Rate Limiting Configuration (Optional)
# -----------------------------------------------------------------------------

# Maximum number of API requests allowed per minute per client IP.
# Protects the backend from abuse and excessive third-party API calls.
# RATE_LIMIT_PER_MINUTE=60


# -----------------------------------------------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------------------------------------------

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG for development, INFO or WARNING for production.
# LOG_LEVEL=INFO

# Path to the log file. Leave empty to log only to stdout/stderr.
# LOG_FILE=./logs/finance_backend.log


# -----------------------------------------------------------------------------
# External Notification Services (Optional)
# -----------------------------------------------------------------------------

# Twilio credentials for SMS-based OTP and alerts (Indian mobile numbers).
# Sign up at: https://www.twilio.com
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# SMTP configuration for email notifications (tax reminders, SIP alerts, etc.).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@yourapp.in
